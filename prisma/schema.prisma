// 방법닷컴 Prisma 스키마
// 상세: docs/PROJECT_DESIGN.md §3.2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────── User ───────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  handle       String   @unique
  name         String?
  avatarUrl    String?
  bio          String?
  tier         Tier     @default(NONE)
  methodScore  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  methods        Method[]
  interactions   Interaction[]
  requests       Request[]
  followedBy     Follow[]      @relation("followee")
  following      Follow[]      @relation("follower")

  @@index([methodScore])
}

enum Tier {
  NONE
  BRONZE
  SILVER
  GOLD
  DIAMOND
}

// ─────────────── Method ───────────────
model Method {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  situation   String   // IF
  action      String   // THEN
  result      String   // SO
  mediaUrl    String?
  detail      String?  // 마크다운 상세 설명 (선택, 최대 2000자)
  sources     String[] // 출처 URL (최대 3개)
  difficulty  Int      @default(1)
  cost        Cost     @default(FREE)
  duration    String?

  views       Int      @default(0)
  saves       Int      @default(0)
  usefuls     Int      @default(0)
  tried       Int      @default(0)
  successes   Int      @default(0)
  fails       Int      @default(0)
  remixes     Int      @default(0)
  outdated    Int      @default(0)
  score       Int      @default(0)
  lastActivityAt DateTime @default(now())

  parentId    String?  // Remix 원본
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author       User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent       Method?         @relation("MethodRemix", fields: [parentId], references: [id])
  children     Method[]        @relation("MethodRemix")
  problems     MethodProblem[]
  contexts     MethodContext[]
  interactions Interaction[]
  answers      RequestAnswer[]

  @@index([authorId])
  @@index([score])
  @@index([lastActivityAt])
  @@index([createdAt])
}

enum Cost {
  FREE
  LOW
  MID
  HIGH
}

// ─────────────── Problem (해시태그) ───────────────
model Problem {
  id           String   @id @default(cuid())
  title        String   @unique
  slug         String   @unique
  category     String?
  methodCount  Int      @default(0)
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())

  methods  MethodProblem[]
  requests Request[]

  @@index([category])
}

model MethodProblem {
  methodId  String
  problemId String

  method  Method  @relation(fields: [methodId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([methodId, problemId])
  @@index([problemId])
}

// ─────────────── Context (버전/시점/기기 등 부가 메타데이터) ───────────────
model Context {
  id          String   @id @default(cuid())
  title       String   @unique
  slug        String   @unique
  methodCount Int      @default(0)
  createdAt   DateTime @default(now())

  methods MethodContext[]
}

model MethodContext {
  methodId  String
  contextId String

  method  Method  @relation(fields: [methodId], references: [id], onDelete: Cascade)
  context Context @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@id([methodId, contextId])
  @@index([contextId])
}

// ─────────────── Interaction ───────────────
model Interaction {
  id             String            @id @default(cuid())
  userId         String
  methodId       String
  type           InteractionType
  comment        String?           // 자유 설명
  outdatedReason OutdatedReason?   // OUTDATED 전용 카테고리
  createdAt      DateTime          @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  method Method @relation(fields: [methodId], references: [id], onDelete: Cascade)

  @@unique([userId, methodId, type])
  @@index([methodId, type])
  @@index([userId, type])
}

enum InteractionType {
  VIEW
  SAVE
  USEFUL
  TRIED
  SUCCESS
  FAIL
  REMIX
  OUTDATED
}

enum OutdatedReason {
  CONTEXT_CHANGED   // 환경/버전이 바뀜
  BETTER_ALTERNATIVE // 더 나은 대안
  EVIDENCE_REFUTED  // 연구/사실 반박
  HARMFUL           // 위험/해로움
  UNCLEAR           // 설명 부족
  OTHER             // 기타
}

// ─────────────── Request (방법 요청) ───────────────
model Request {
  id          String        @id @default(cuid())
  requesterId String
  title       String
  situation   String
  problem     String
  tried       String?
  constraints String?
  desired     String
  bounty      Int           @default(0)
  upvotes     Int           @default(0)
  status      RequestStatus @default(OPEN)
  problemId   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  requester User            @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  tag       Problem?        @relation(fields: [problemId], references: [id])
  answers   RequestAnswer[]

  @@index([status, createdAt])
}

enum RequestStatus {
  OPEN
  ANSWERED
  RESOLVED
}

model RequestAnswer {
  id        String   @id @default(cuid())
  requestId String
  methodId  String
  chosen    Boolean  @default(false)
  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  method  Method  @relation(fields: [methodId], references: [id], onDelete: Cascade)

  @@unique([requestId, methodId])
}

// ─────────────── Follow ───────────────
model Follow {
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  follower User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
}
